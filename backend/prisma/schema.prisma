generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  avatar       String?
  phone        String?
  role         Role       @default(athlete)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bookings     Booking[]
  facilities   Facility[] @relation("OwnerFacilities")
  favorites    Favorite[]
}

model Facility {
  id              String          @id @default(cuid())
  ownerId         String
  name            String
  sport           String
  city            String
  district        String
  address         String
  lat             Float?
  lng             Float?
  description     String          @default("")
  pricePerHour    Int
  openTime        String          @default("08:00")
  closeTime       String          @default("22:00")
  status          FacilityStatus  @default(active)
  isApproved      Boolean         @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  bookings        Booking[]
  courts          Court[]
  owner           User            @relation("OwnerFacilities", fields: [ownerId], references: [id], onDelete: Cascade)
  photos          FacilityPhoto[]
  favorites       Favorite[]
  moderationLogs  ModerationLog[]

  @@index([city, sport])
  @@index([isApproved, status])
}

model Court {
  id         String    @id @default(cuid())
  facilityId String
  name       String
  createdAt  DateTime  @default(now())
  bookings   Booking[]
  facility   Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

model FacilityPhoto {
  id         String   @id @default(cuid())
  facilityId String
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String        @id @default(cuid())
  userId     String?
  facilityId String
  date       String
  startTime  String
  endTime    String
  status     BookingStatus @default(confirmed)
  totalPrice Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  createdBy  String        @default("athlete")
  guestName  String?
  guestPhone String?
  courtId    String?
  court      Court?        @relation(fields: [courtId], references: [id])
  facility   Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courtId, date, startTime])
  @@index([userId])
  @@index([facilityId, date])
  @@index([date])
}

model Favorite {
  userId     String
  facilityId String
  createdAt  DateTime @default(now())
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
}

model ModerationLog {
  id         String   @id @default(cuid())
  facilityId String
  action     String
  actor      String
  reason     String?
  createdAt  DateTime @default(now())
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

enum Role {
  athlete
  organizer
}

enum FacilityStatus {
  active
  inactive
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}
